platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first"
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # Fix -G flag issue in ALL xcconfig files (gRPC/abseil)
  Dir.glob(File.join(installer.sandbox.root, '**/*.xcconfig')).each do |xcconfig_path|
    xcconfig_content = File.read(xcconfig_path)
    if xcconfig_content.include?('-G')
      puts "Removing -G flag from: #{xcconfig_path}"
      xcconfig_content.gsub!(/-G\s*\S*/, '')
      File.open(xcconfig_path, 'w') { |f| f.write(xcconfig_content) }
    end
  end

  # Fix all targets including Pods
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Remove -G from ALL compiler/linker flags
      %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS OTHER_LDFLAGS OTHER_SWIFT_FLAGS 
         GCC_PREPROCESSOR_DEFINITIONS CLANG_CXX_FLAGS].each do |key|
        if config.build_settings[key]
          config.build_settings[key] = config.build_settings[key].gsub(/(-G\s*\S*|-G)/, '').strip
        end
      end
      
      # Fix for x86_64 simulator - EXCLUDED_ARCHS
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
      
      # Ensure proper linking for Firebase/gRPC
      ldflags = config.build_settings['OTHER_LDFLAGS'] || ['$(inherited)']
      ldflags = [ldflags] if ldflags.is_a?(String)
      ldflags = ldflags.flatten.uniq
      ldflags << '-ObjC' unless ldflags.include?('-ObjC')
      ldflags << '-lc++' unless ldflags.include?('-lc++')
      config.build_settings['OTHER_LDFLAGS'] = ldflags
    end
  end
  
  # Fix Xcode 15+ compatibility at project level
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
    config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
    
    # Remove -G from project level too
    %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS].each do |key|
      if config.build_settings[key]
        config.build_settings[key] = config.build_settings[key].gsub(/(-G\s*\S*|-G)/, '').strip
      end
    end
  end
end