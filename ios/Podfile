platform :ios, '13.0'

source 'https://cdn.cocoapods.org/'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Firebase pods - versions compatible with Flutter plugins
  pod 'Firebase/Core', '~> 11.0'
  pod 'Firebase/Auth', '~> 11.0'
  pod 'Firebase/Firestore', '~> 11.0'
  pod 'Firebase/Crashlytics', '~> 11.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      
      # Fix for Xcode 15+ linker issues
      config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
      config.build_settings['OTHER_LDFLAGS'] << '-ObjC'
      config.build_settings['OTHER_LDFLAGS'] << '-lc++'
    end
  end
  
  # Set deployment target for all pods
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
  end
end