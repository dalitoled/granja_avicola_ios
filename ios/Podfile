platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'
ENV['CFLAGS'] = '-Wno-unused-command-line-argument'
ENV['CXXFLAGS'] = '-Wno-unused-command-line-argument'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. Run flutter pub get first"
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # Fix -G flag in ALL files
  Dir.glob(File.join(installer.sandbox.root, '**/*.xcconfig')).each do |xcconfig_path|
    content = File.read(xcconfig_path)
    if content.include?('-G')
      puts "Patching: #{xcconfig_path}"
      content = content.gsub(/-G\s*\S*/, '')
      File.write(xcconfig_path, content)
    end
  end

  # Fix all targets
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['GCC_WARN_INHIBIT_UNIVERSAL_WARNING'] = 'YES'
      
      # Remove -G from ALL compiler flags
      %w[OTHER_CFLAGS OTHER_CPLUSPLUSFLAGS OTHER_LDFLAGS OTHER_SWIFT_FLAGS 
         GCC_PREPROCESSOR_DEFINITIONS CLANG_CXX_FLAGS].each do |key|
        if config.build_settings[key]
          config.build_settings[key] = config.build_settings[key].to_s.gsub(/-G\s*\S*/, '').gsub(/-G/, '').strip
        end
      end
      
      # Fix for simulator
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
      
      # Fix header search paths for abseil/gRPC
      config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['HEADER_SEARCH_PATHS'] = [
        '$(inherited)',
        '"${PODS_ROOT}/Headers/Public"',
        '"${PODS_ROOT}/abseil/src"',
        '"${PODS_ROOT}/BoringSSL-GRPC/src/include"',
        '"${PODS_ROOT}/gRPC-Core/src/core/lib/security/credentials"'
      ]
      
      # Proper linking
      ldflags = config.build_settings['OTHER_LDFLAGS'] || ['$(inherited)']
      ldflags = [ldflags].flatten.uniq
      ldflags << '-ObjC' unless ldflags.include?('-ObjC')
      ldflags << '-lc++' unless ldflags.include?('-lc++')
      config.build_settings['OTHER_LDFLAGS'] = ldflags
    end
  end
  
  # Project level fixes
  installer.pods_project.build_configurations.each do |config|
    config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'gnu++17'
    config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
    config.build_settings['GCC_WARN_INHIBIT_UNIVERSAL_WARNING'] = 'YES'
  end
end